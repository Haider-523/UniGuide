@model UniGuide.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div style="min-height: 90vh; background: #f8f9fa;
    display: flex; align-items: center; padding: 40px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5">

                <div class="text-center mb-4">
                    <h2 style="font-weight: 800; color: #1a1a2e;">Welcome Back</h2>
                    <p style="color: #666;">Login to your UniGuide account</p>
                </div>

                <div style="background: white; border-radius: 20px; padding: 40px;
                    box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             style="background: #f8d7da; border-radius: 10px;
                            padding: 12px 16px; margin-bottom: 20px;
                            color: #721c24; font-size: 0.9rem;">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg"
                                   placeholder="your@email.com"
                                   style="border-radius: 10px;" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" type="password"
                                   class="form-control form-control-lg"
                                   placeholder="Your password"
                                   style="border-radius: 10px;" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit"
                                style="width: 100%;
                            background: linear-gradient(135deg, #0f3460, #1a1a2e);
                            color: white; border: none; padding: 16px;
                            border-radius: 12px; font-size: 1rem;
                            font-weight: 700; cursor: pointer;">
                            Login →
                        </button>

                        <p class="text-center mt-3" style="color: #666; font-size: 0.9rem;">
                            Don't have an account?
                            <a asp-action="Register" style="color: #0f3460; font-weight: 600;">
                                Register here
                            </a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>