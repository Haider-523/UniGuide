@model IEnumerable<UniGuide.Models.Student>
@{
    ViewData["Title"] = "Students";
    Layout = "_AdminLayout";
}

<div style="margin-bottom: 24px;">
    <h4 style="font-weight: 800; color: #1a1a2e; margin-bottom: 4px;">Students</h4>
    <p style="color: #888; margin: 0; font-size: 0.88rem;">
        @Model.Count() registered students
    </p>
</div>

<div style="background: white; border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden;">
    <table class="table table-hover mb-0">
        <thead style="background: #f8f9fa;">
            <tr>
                <th style="padding: 16px 20px; font-size: 0.82rem; color: #888;">#</th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">Name</th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">Email</th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">City</th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">Group</th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">Marks</th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">Joined</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td style="padding: 16px 20px; color: #888; font-size: 0.85rem;">
                        #@student.StudentID
                    </td>
                    <td style="padding: 16px; font-weight: 600; color: #1a1a2e;">
                        @student.FullName
                    </td>
                    <td style="padding: 16px; color: #555; font-size: 0.88rem;">
                        @student.Email
                    </td>
                    <td style="padding: 16px; color: #555;">@student.City</td>
                    <td style="padding: 16px;">
                        <span style="background: #e8f4fd; color: #0f3460;
                            padding: 3px 10px; border-radius: 10px;
                            font-size: 0.78rem; font-weight: 600;">
                            @student.InterGroup
                        </span>
                    </td>
                    <td style="padding: 16px; color: #555;">@student.InterMarksPercent%</td>
                    <td style="padding: 16px; color: #888; font-size: 0.85rem;">
                        @student.CreatedAt.ToString("MMM dd, yyyy")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>