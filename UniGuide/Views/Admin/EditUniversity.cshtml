@model UniGuide.Models.University
@{
    ViewData["Title"] = "Edit University";
    Layout = "_AdminLayout";
}

<div style="max-width: 700px;">
    <div style="margin-bottom: 24px;">
        <a asp-action="Universities"
               style="color: #888; text-decoration: none; font-size: 0.88rem;">
            ← Back to Universities
        </a>
        <h4 style="font-weight: 800; color: #1a1a2e; margin-top: 8px;">
            Edit University
        </h4>
    </div>

    <div style="background: white; border-radius: 16px; padding: 36px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UniversityID" />
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">University Name</label>
                    <input asp-for="Name" class="form-control"
                           style="border-radius: 8px;" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">City</label>
                    <select asp-for="City" class="form-select"
                            style="border-radius: 8px;">
                        <option value="Lahore">Lahore</option>
                        <option value="Islamabad">Islamabad</option>
                        <option value="Karachi">Karachi</option>
                        <option value="Peshawar">Peshawar</option>
                        <option value="Quetta">Quetta</option>
                        <option value="Multan">Multan</option>
                        <option value="Faisalabad">Faisalabad</option>
                        <option value="Rawalpindi">Rawalpindi</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Type</label>
                    <select asp-for="Type" class="form-select"
                            style="border-radius: 8px;">
                        <option value="Public">Public</option>
                        <option value="Private">Private</option>
                        <option value="Semi-Government">Semi-Government</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">HEC Ranking</label>
                    <input asp-for="HECRanking" type="number"
                           class="form-control" style="border-radius: 8px;" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Established Year</label>
                    <input asp-for="EstablishedYear" type="number"
                           class="form-control" style="border-radius: 8px;" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Website URL</label>
                    <input asp-for="Website" class="form-control"
                           style="border-radius: 8px;" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control"
                              rows="3" style="border-radius: 8px;"></textarea>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="HasHostel" class="form-check-input" type="checkbox" />
                        <label class="form-check-label fw-semibold">Hostel Available</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="HasTransport" class="form-check-input" type="checkbox" />
                        <label class="form-check-label fw-semibold">Transport Available</label>
                    </div>
                </div>
            </div>
            <div style="margin-top: 28px; display: flex; gap: 12px;">
                <button type="submit"
                        style="background: #0f3460; color: white; border: none;
                    padding: 14px 32px; border-radius: 10px;
                    font-weight: 700; cursor: pointer;">
                    ✅ Update University
                </button>
                <a asp-action="Universities"
                       style="background: #f0f0f0; color: #555; padding: 14px 32px;
                    border-radius: 10px; text-decoration: none; font-weight: 600;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>