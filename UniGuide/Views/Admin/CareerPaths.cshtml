@model IEnumerable<UniGuide.Models.CareerPath>
@{
    ViewData["Title"] = "Career Paths";
    Layout = "_AdminLayout";
}

<div style="display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 24px;">
    <div>
        <h4 style="font-weight: 800; color: #1a1a2e; margin-bottom: 4px;">
            Career Paths
        </h4>
        <p style="color: #888; margin: 0; font-size: 0.88rem;">
            @Model.Count() career paths in system
        </p>
    </div>
    <a asp-action="AddCareerPath"
           style="background: #0f3460; color: white; padding: 12px 24px;
        border-radius: 10px; text-decoration: none;
        font-weight: 600; font-size: 0.9rem;">
        ➕ Add Career Path
    </a>
</div>

<div style="background: white; border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden;">
    <table class="table table-hover mb-0">
        <thead style="background: #f8f9fa;">
            <tr>
                <th style="padding: 16px 20px; font-size: 0.82rem; color: #888;">
                    Job Title
                </th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">
                    Program
                </th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">
                    University
                </th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">
                    Salary Range
                </th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">
                    Demand
                </th>
                <th style="padding: 16px; font-size: 0.82rem; color: #888;">
                    Actions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var career in Model)
            {
                <tr>
                    <td style="padding: 16px 20px; font-weight: 600; color: #1a1a2e;">
                        @career.JobTitle
                    </td>
                    <td style="padding: 16px; color: #555; font-size: 0.88rem;">
                        @career.Program?.ProgramName
                    </td>
                    <td style="padding: 16px; color: #555; font-size: 0.85rem;">
                        @career.Program?.University?.Name
                    </td>
                    <td style="padding: 16px; color: #555; font-size: 0.85rem;">
                        PKR @career.MinSalaryPKR.ToString("N0") —
                        @career.MaxSalaryPKR.ToString("N0")
                    </td>
                    <td style="padding: 16px;">
                        <span style="background: @(career.DemandLevel == "High"
                                                                                                  ? "#d4edda" : career.DemandLevel == "Medium"
                                                                                                  ? "#fff3cd" : "#f8d7da");
                            color: @(career.DemandLevel == "High"
                                                                                                  ? "#155724" : career.DemandLevel == "Medium"
                                                                                                  ? "#856404" : "#721c24");
                            padding: 3px 10px; border-radius: 10px;
                            font-size: 0.78rem; font-weight: 600;">
                            @career.DemandLevel
                        </span>
                    </td>
                    <td style="padding: 16px;">
                        <form asp-action="DeleteCareerPath" method="post"
                              onsubmit="return confirm('Delete @career.JobTitle?')">
                            <input type="hidden" name="id" value="@career.CareerID" />
                            <button type="submit"
                                    style="background: #f8d7da; color: #721c24;
                                border: none; padding: 6px 14px;
                                border-radius: 6px; font-size: 0.8rem;
                                font-weight: 600; cursor: pointer;">
                                🗑️ Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>