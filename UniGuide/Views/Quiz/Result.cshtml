@model UniGuide.Models.QuizViewModel
@{
    ViewData["Title"] = "Your Results";
}

<div style="background: #f8f9fa; min-height: 90vh; padding: 50px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 text-center">

                <!-- Result Card -->
                <div style="background: linear-gradient(135deg, #1a1a2e, #0f3460);
                    border-radius: 24px; padding: 48px 40px;
                    color: white; margin-bottom: 28px;
                    box-shadow: 0 8px 40px rgba(15,52,96,0.3);">

                    <div style="font-size: 3.5rem; margin-bottom: 16px;">🎯</div>

                    <div style="background: rgba(79,195,247,0.15);
                        border: 1px solid rgba(79,195,247,0.3);
                        border-radius: 30px; padding: 6px 20px;
                        font-size: 0.85rem; color: #4fc3f7;
                        display: inline-block; margin-bottom: 20px;">
                        Your Interest Profile
                    </div>

                    <h1 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 12px;">
                        @Model.ResultProfile
                    </h1>

                    <p style="opacity: 0.75; font-size: 0.95rem; margin: 0;">
                        Based on your answers, you are best suited for:
                    </p>
                </div>

                <!-- Recommended Fields -->
                <div style="background: white; border-radius: 20px; padding: 36px;
                    box-shadow: 0 2px 20px rgba(0,0,0,0.07);
                    margin-bottom: 24px; text-align: left;">

                    <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 20px;">
                        📚 Recommended Degree Fields
                    </h5>

                    <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                        @foreach (var field in Model.RecommendedField!.Split(','))
                        {
                            <span style="background: #e8f4fd; color: #0f3460;
                                padding: 8px 18px; border-radius: 20px;
                                font-size: 0.88rem; font-weight: 600;
                                border: 1px solid #b8d9f5;">
                                @field.Trim()
                            </span>
                        }
                    </div>
                </div>

                <!-- What next -->
                <div style="background: white; border-radius: 20px; padding: 36px;
                    box-shadow: 0 2px 20px rgba(0,0,0,0.07);
                    margin-bottom: 24px; text-align: left;">
                    <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 16px;">
                        🚀 What Should You Do Next?
                    </h5>
                    <p style="color: #555; line-height: 1.8; margin-bottom: 20px;">
                        Now that you know your interest profile, use our Smart Matching
                        tool to find universities offering these programs — filtered by
                        your marks, city and budget.
                    </p>
                    <a asp-controller="Match" asp-action="Index"
                           style="display: inline-block; background: #0f3460; color: white;
                        padding: 14px 32px; border-radius: 12px;
                        text-decoration: none; font-weight: 700; font-size: 0.95rem;">
                        🔍 Find Matching Universities →
                    </a>
                </div>

                <!-- Retake -->
                <a asp-action="Index"
                       style="color: #666; font-size: 0.88rem; text-decoration: none;">
                    ↺ Retake the quiz
                </a>

            </div>
        </div>
    </div>
</div>