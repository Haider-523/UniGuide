@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    min-height: 92vh; width: 100vw; margin-left: calc(-50vw + 50%);
    display: flex; align-items: center;
    position: relative; overflow: hidden;">

    <!-- Background circles decoration -->
    <div style="position: absolute; width: 400px; height: 400px;
    border-radius: 50%; background: rgba(79,195,247,0.06);
    top: -100px; right: -100px;"></div>
    <div style="position: absolute; width: 250px; height: 250px;
    border-radius: 50%; background: rgba(79,195,247,0.04);
    bottom: -50px; left: -50px;"></div>

    <div class="container text-center text-white" style="position: relative; z-index: 1;">

        <!-- Badge -->
        <div style="display: inline-block; background: rgba(79,195,247,0.15);
            border: 1px solid rgba(79,195,247,0.3); border-radius: 30px;
            padding: 6px 20px; font-size: 0.85rem; color: #4fc3f7;
            margin-bottom: 28px; font-weight: 500;">
            🇵🇰 Pakistan's Smartest Admission Guide
        </div>

        <!-- Headline -->
        <h1 style="font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800;
            line-height: 1.15; margin-bottom: 20px; letter-spacing: -0.5px;">
            Find the Right University<br />
            <span style="color: #4fc3f7;">For Your Future</span>
        </h1>

        <!-- Subheading -->
        <p style="font-size: 1.15rem; opacity: 0.75; max-width: 560px;
            margin: 0 auto 40px; line-height: 1.7;">
            Stop guessing. UniGuide matches you with universities and programs
            that fit your marks, budget and interests — instantly.
        </p>

        <!-- CTA Buttons -->
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a asp-controller="Match" asp-action="Index"
                   style="background: #4fc3f7; color: #1a1a2e; font-weight: 700;
                padding: 16px 36px; border-radius: 12px; text-decoration: none;
                font-size: 1.05rem; transition: all 0.2s; display: inline-block;"
                   onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 25px rgba(79,195,247,0.4)'"
                   onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'">
                🔍 Find My University
            </a>
            <a asp-controller="University" asp-action="Index"
                   style="background: transparent; color: white; font-weight: 600;
                padding: 16px 36px; border-radius: 12px; text-decoration: none;
                font-size: 1.05rem; border: 1.5px solid rgba(255,255,255,0.3);
                transition: all 0.2s; display: inline-block;"
                   onmouseover="this.style.borderColor='rgba(255,255,255,0.7)'"
                   onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'">
                Browse Universities
            </a>
        </div>

        <!-- Stats -->
        <div style="display: flex; justify-content: center; gap: 48px;
            margin-top: 64px; flex-wrap: wrap;">
            <div>
                <div style="font-size: 2rem; font-weight: 800; color: #4fc3f7;">10+</div>
                <div style="font-size: 0.85rem; opacity: 0.6; margin-top: 4px;">Universities</div>
            </div>
            <div style="width: 1px; background: rgba(255,255,255,0.1);"></div>
            <div>
                <div style="font-size: 2rem; font-weight: 800; color: #4fc3f7;">20+</div>
                <div style="font-size: 0.85rem; opacity: 0.6; margin-top: 4px;">Programs</div>
            </div>
            <div style="width: 1px; background: rgba(255,255,255,0.1);"></div>
            <div>
                <div style="font-size: 2rem; font-weight: 800; color: #4fc3f7;">Smart</div>
                <div style="font-size: 0.85rem; opacity: 0.6; margin-top: 4px;">AI Matching</div>
            </div>
            <div style="width: 1px; background: rgba(255,255,255,0.1);"></div>
            <div>
                <div style="font-size: 2rem; font-weight: 800; color: #4fc3f7;">Free</div>
                <div style="font-size: 0.85rem; opacity: 0.6; margin-top: 4px;">Always</div>
            </div>
        </div>
    </div>
</div>

<!-- How It Works -->
<div style="background: #f8f9fa; padding: 80px 0;">
    <div class="container">
        <div class="text-center mb-56" style="margin-bottom: 52px;">
            <h2 style="font-size: 2rem; font-weight: 800; color: #1a1a2e;">
                How UniGuide Works
            </h2>
            <p style="color: #666; font-size: 1rem; margin-top: 10px;">
                3 simple steps to find your perfect university
            </p>
        </div>

        <div class="row g-4 justify-content-center">

            <!-- Step 1 -->
            <div class="col-md-4">
                <div style="background: white; border-radius: 16px; padding: 36px 28px;
                    text-align: center; height: 100%;
                    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
                    transition: transform 0.2s;"
                     onmouseover="this.style.transform='translateY(-6px)'"
                     onmouseout="this.style.transform='translateY(0)'">
                    <div style="width: 64px; height: 64px; background: #e8f4fd;
                        border-radius: 16px; display: flex; align-items: center;
                        justify-content: center; margin: 0 auto 20px;
                        font-size: 1.8rem;">
                        📋
                    </div>
                    <div style="background: #0f3460; color: white; width: 28px; height: 28px;
                        border-radius: 50%; display: flex; align-items: center;
                        justify-content: center; margin: 0 auto 16px;
                        font-size: 0.8rem; font-weight: 700;">
                        1
                    </div>
                    <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 12px;">
                        Enter Your Details
                    </h5>
                    <p style="color: #666; font-size: 0.92rem; line-height: 1.6; margin: 0;">
                        Tell us your Inter group, marks percentage,
                        preferred city and budget per semester.
                    </p>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="col-md-4">
                <div style="background: white; border-radius: 16px; padding: 36px 28px;
                    text-align: center; height: 100%;
                    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
                    transition: transform 0.2s;"
                     onmouseover="this.style.transform='translateY(-6px)'"
                     onmouseout="this.style.transform='translateY(0)'">
                    <div style="width: 64px; height: 64px; background: #e8f4fd;
                        border-radius: 16px; display: flex; align-items: center;
                        justify-content: center; margin: 0 auto 20px;
                        font-size: 1.8rem;">
                        🤖
                    </div>
                    <div style="background: #0f3460; color: white; width: 28px; height: 28px;
                        border-radius: 50%; display: flex; align-items: center;
                        justify-content: center; margin: 0 auto 16px;
                        font-size: 0.8rem; font-weight: 700;">
                        2
                    </div>
                    <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 12px;">
                        Smart Matching
                    </h5>
                    <p style="color: #666; font-size: 0.92rem; line-height: 1.6; margin: 0;">
                        UniGuide instantly filters universities by your merit,
                        budget and inter group — no manual searching needed.
                    </p>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="col-md-4">
                <div style="background: white; border-radius: 16px; padding: 36px 28px;
                    text-align: center; height: 100%;
                    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
                    transition: transform 0.2s;"
                     onmouseover="this.style.transform='translateY(-6px)'"
                     onmouseout="this.style.transform='translateY(0)'">
                    <div style="width: 64px; height: 64px; background: #e8f4fd;
                        border-radius: 16px; display: flex; align-items: center;
                        justify-content: center; margin: 0 auto 20px;
                        font-size: 1.8rem;">
                        🎯
                    </div>
                    <div style="background: #0f3460; color: white; width: 28px; height: 28px;
                        border-radius: 50%; display: flex; align-items: center;
                        justify-content: center; margin: 0 auto 16px;
                        font-size: 0.8rem; font-weight: 700;">
                        3
                    </div>
                    <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 12px;">
                        See Your Career Path
                    </h5>
                    <p style="color: #666; font-size: 0.92rem; line-height: 1.6; margin: 0;">
                        Each matched program shows real career options and
                        salary ranges so you choose with confidence.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div style="background: white; padding: 80px 0;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div style="display: inline-block; background: #e8f4fd; color: #0f3460;
                    border-radius: 20px; padding: 4px 16px;
                    font-size: 0.82rem; font-weight: 600; margin-bottom: 16px;">
                    Why UniGuide?
                </div>
                <h2 style="font-size: 1.9rem; font-weight: 800;
                    color: #1a1a2e; margin-bottom: 20px; line-height: 1.3;">
                    Everything a Pakistani student needs in one place
                </h2>
                <p style="color: #666; line-height: 1.8; margin-bottom: 32px;">
                    No more visiting 10 different university websites.
                    No more asking random people on Facebook groups.
                    UniGuide gives you intelligent, personalized guidance.
                </p>

                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @foreach (var feature in new[] {
                        ("✅", "Merit-based filtering — only shows universities you qualify for"),
                        ("✅", "Budget matching — no surprises, only affordable options"),
                        ("✅", "Career previews — know your job prospects before you apply"),
                        ("✅", "All info in one place — fees, hostel, transport, ranking")
                    })
                    {
                        <div style="display: flex; gap: 12px; align-items: flex-start;">
                            <span style="font-size: 1rem; margin-top: 2px;">@feature.Item1</span>
                            <span style="color: #444; font-size: 0.95rem;">@feature.Item2</span>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-6">
                <div style="background: linear-gradient(135deg, #1a1a2e, #0f3460);
                    border-radius: 20px; padding: 40px; color: white;">
                    <h5 style="color: #4fc3f7; margin-bottom: 24px; font-weight: 700;">
                        🔍 Quick Match Preview
                    </h5>
                    @foreach (var item in new[] {
                        ("FAST Lahore", "BS Computer Science", "PKR 95,000", "HEC #4"),
                        ("UET Lahore", "BS Computer Engineering", "PKR 35,000", "HEC #3"),
                        ("Punjab University", "BS IT", "PKR 18,000", "HEC #8")
                    })
                    {
                        <div style="background: rgba(255,255,255,0.07); border-radius: 12px;
                            padding: 16px 20px; margin-bottom: 12px;
                            border-left: 3px solid #4fc3f7;">
                            <div style="font-weight: 600; font-size: 0.95rem;">
                                @item.Item2
                            </div>
                            <div style="color: rgba(255,255,255,0.6); font-size: 0.82rem;
                                margin-top: 4px;">
                                @item.Item1 &nbsp;·&nbsp; @item.Item4 &nbsp;·&nbsp;
                                <span style="color: #4fc3f7;">@item.Item3/sem</span>
                            </div>
                        </div>
                    }
                    <a asp-controller="Match" asp-action="Index"
                           style="display: block; text-align: center; background: #4fc3f7;
                        color: #1a1a2e; font-weight: 700; padding: 14px;
                        border-radius: 10px; text-decoration: none;
                        margin-top: 20px; font-size: 0.95rem;">
                        Get Your Full Results →
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div style="background: linear-gradient(135deg, #1a1a2e, #0f3460);
    padding: 80px 0; text-align: center;">
    <div class="container">
        <h2 style="color: white; font-size: 2rem; font-weight: 800; margin-bottom: 16px;">
            Ready to find your university?
        </h2>
        <p style="color: rgba(255,255,255,0.7); font-size: 1rem; margin-bottom: 36px;">
            It takes less than 30 seconds. Completely free.
        </p>
        <a asp-controller="Match" asp-action="Index"
               style="background: #4fc3f7; color: #1a1a2e; font-weight: 700;
            padding: 18px 48px; border-radius: 12px; text-decoration: none;
            font-size: 1.1rem; display: inline-block; transition: all 0.2s;"
               onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 25px rgba(79,195,247,0.4)'"
               onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'">
            🎓 Start For Free
        </a>
    </div>
</div>