<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniGuide</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniGuide.styles.css" asp-append-version="true" />
    <style>
    body {
        opacity: 0;
        animation: fadeIn 0.35s ease forwards;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>
</head>
<body>
    <header>
    <nav class="navbar navbar-expand-lg sticky-top"
         style="background: #1a1a2e; padding: 14px 0; box-shadow: 0 2px 12px rgba(0,0,0,0.3);">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index"
               style="color: white; font-size: 1.4rem; font-weight: 700; text-decoration: none;">
                🎓 <span style="color: #4fc3f7;">Uni</span>Guide
            </a>

            <!-- Mobile toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    style="border-color: rgba(255,255,255,0.3);">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav links -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-1">

    <!-- Home -->
    <li class="nav-item">
        <a class="nav-link" asp-controller="Home" asp-action="Index"
           style="color: rgba(255,255,255,0.85); font-weight: 500;
                  padding: 8px 16px; border-radius: 8px; transition: background 0.2s;"
           onmouseover="this.style.background='rgba(255,255,255,0.1)'"
           onmouseout="this.style.background='transparent'">
            Home
        </a>
    </li>

    <!-- Universities -->
    <li class="nav-item">
        <a class="nav-link" asp-controller="University" asp-action="Index"
           style="color: rgba(255,255,255,0.85); font-weight: 500;
                  padding: 8px 16px; border-radius: 8px; transition: background 0.2s;"
           onmouseover="this.style.background='rgba(255,255,255,0.1)'"
           onmouseout="this.style.background='transparent'">
            Universities
        </a>
    </li>

    <li class="nav-item">
        <a class="nav-link" asp-controller="Quiz" asp-action="Index"
           style="color: rgba(255,255,255,0.85); font-weight: 500;
                  padding: 8px 16px; border-radius: 8px; transition: background 0.2s;"
           onmouseover="this.style.background='rgba(255,255,255,0.1)'"
           onmouseout="this.style.background='transparent'">
            🧠 Interest Quiz
        </a>
    </li>

    <!-- ✅ Login/Register/Logout — ADD HERE -->
    @if (Context.Session.GetString("StudentName") != null)
    {
        <li class="nav-item">
            <a asp-controller="Dashboard" asp-action="Index"
               style="color: rgba(255,255,255,0.85); padding: 8px 16px;
                      font-weight: 500; text-decoration: none;">
                👋 @Context.Session.GetString("StudentName")
            </a>
        </li>

        <li class="nav-item">
            <a asp-controller="Dashboard" asp-action="Index"
               style="color: rgba(255,255,255,0.85); font-weight: 500;
                      padding: 8px 16px; border-radius: 8px; text-decoration: none;"
               onmouseover="this.style.background='rgba(255,255,255,0.1)'"
               onmouseout="this.style.background='transparent'">
                Dashboard
            </a>
        </li>

        <li class="nav-item">
            <a asp-controller="Account" asp-action="Logout"
               style="color: rgba(255,255,255,0.6); padding: 8px 16px;
                      font-size: 0.9rem; text-decoration: none;">
                Logout
            </a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a asp-controller="Account" asp-action="Login"
               style="color: rgba(255,255,255,0.85); font-weight: 500;
                      padding: 8px 16px; border-radius: 8px; text-decoration: none;"
               onmouseover="this.style.background='rgba(255,255,255,0.1)'"
               onmouseout="this.style.background='transparent'">
                Login
            </a>
        </li>
        <li class="nav-item">
            <a asp-controller="Account" asp-action="Register"
               style="background: rgba(79,195,247,0.15); color: #4fc3f7;
                      font-weight: 600; padding: 8px 20px; border-radius: 8px;
                      text-decoration: none; border: 1px solid rgba(79,195,247,0.3);"
               onmouseover="this.style.background='rgba(79,195,247,0.25)'"
               onmouseout="this.style.background='rgba(79,195,247,0.15)'">
                Register
            </a>
        </li>
    }

    <!-- Find My University -->
    <li class="nav-item">
        <a class="nav-link" asp-controller="Match" asp-action="Index"
           style="background: #4fc3f7; color: #1a1a2e !important;
                  font-weight: 600; padding: 8px 20px; border-radius: 8px;
                  transition: opacity 0.2s;"
           onmouseover="this.style.opacity='0.85'"
           onmouseout="this.style.opacity='1'">
            🔍 Find My University
        </a>
    </li>

</ul>
            </div>
        </div>
    </nav>
</header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted"
        style="background: #1a1a2e; color: rgba(255,255,255,0.6) !important;
               padding: 20px 0; margin-top: 60px;">
    <div class="container text-center">
        <span style="color: rgba(255,255,255,0.6);">
            © 2026 UniGuide — Pakistan's Smartest Admission Guide
        </span>
    </div>
</footer>

    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - UniGuide - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
<script>
// Secret: press Ctrl+Shift+A to go to admin
document.addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.shiftKey && e.key === 'A') {
        window.location.href = '/Admin/Login';
    }
});
</script>
</html>
